# ============================================================
# VoiceGuard — Production Environment Variables Template
# ============================================================
# Copy this file's variable names into your Vercel dashboard
# under: Project → Settings → Environment Variables
#
# ⚠️  NEVER commit real secrets to Git. This file shows only
#     the variable NAMES — replace the placeholder values.
# ============================================================

# ── Supabase (get from: supabase.com → Project Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Groq AI (free at: console.groq.com → API Keys) ──
GROQ_API_KEY=gsk_your_groq_key_here

# ── NewsAPI (free at: newsapi.org/register) ──
NEWS_API_KEY=your_newsapi_key_here

# ── VoiceGuard Python API ──
# URL of the deployed Hugging Face Space (no trailing slash)
# Example: https://yourusername-voiceguard-api.hf.space
VOICEGUARD_API_URL=https://YOUR_HF_USERNAME-voiceguard-api.hf.space

# Shared secret between Next.js and Python API (generate a strong random string)
# Must match the VOICEGUARD_INTERNAL_SECRET set on Hugging Face Spaces too
VOICEGUARD_INTERNAL_SECRET=generate_a_strong_random_secret_here
