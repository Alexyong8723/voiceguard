!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
.venv/
venv/
env/

# ML model weights (large binary — deploy separately to HF Spaces)
*.pt
*.pth
*.ckpt
*.bin

